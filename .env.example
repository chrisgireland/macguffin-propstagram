# Copy this file to .env.local and fill in your values.

# Supabase (get from: Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: login (username + password). One line, comma-separated entries: username:hash:role (role = editor or client).
# Generate each hash with: echo -n 'YourPassword' | shasum -a 256 | cut -d' ' -f1
# Example (one editor + one client):
# VITE_LOGINS=editor:PASTE_EDITOR_HASH:editor,client:PASTE_CLIENT_HASH:client
# Or single password only (login as username "editor"): VITE_PASSWORD_HASH=your_hash
